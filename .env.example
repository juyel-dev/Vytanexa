# Vytanexa — Environment Variables
# Copy to .env.local in apps/web and apps/admin (NEVER commit the real file)

# ── Supabase (same project, both apps) ─────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service role key: ADMIN APP ONLY, server-side only, NEVER exposed to
# any client bundle, NEVER prefixed with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=

# ── App URLs ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000          # apps/web
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001         # apps/admin

# ── Future (not required at launch, per PROJECT-CONTEXT.md §3) ──────
# PAYMENT_GATEWAY_KEY=
# PAYMENT_GATEWAY_SECRET=
